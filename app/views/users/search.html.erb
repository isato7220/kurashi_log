<div class="container py-5">
  <div class="mx-auto" style="max-width: 800px;">

    <div class="mb-3">
      <%= link_to "← ホームへ戻る", root_path, class: "text-decoration-none small text-muted" %>
    </div>

    <h2 class="fw-bold mb-4">検索結果</h2>

    <%= form_with url: user_search_path, method: :get, local: true, class: "mb-5" do |f| %>
      <div class="input-group">
        <%= f.text_field :q,
              value: @query,
              placeholder: "ユーザー名・投稿タイトル・メモで検索",
              class: "form-control rounded-pill rounded-end",
              autofocus: true %>
        <%= f.submit "検索", class: "btn btn-success ms-2 rounded-pill px-4" %>
      </div>
    <% end %>

    <% if @query.present? %>

      <section class="mb-5">
        <h5 class="fw-bold mb-3">ユーザー <span class="text-muted fw-normal small">（<%= @users.size %>件）</span></h5>
        <% if @users.any? %>
          <div class="row g-3">
            <% @users.each do |user| %>
              <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-3">
                  <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold"
                         style="width:42px; height:42px; font-size:1.1rem; flex-shrink:0;">
                      <%= user.name[0] %>
                    </div>
                    <div>
                      <p class="fw-semibold mb-0"><%= user.name %></p>
                      <small class="text-muted"><%= user.posts.count %>件の投稿</small>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted">ユーザーが見つかりませんでした</p>
        <% end %>
      </section>

      <section>
        <h5 class="fw-bold mb-3">投稿 <span class="text-muted fw-normal small">（<%= @posts.size %>件）</span></h5>
        <% if @posts.any? %>
          <% @posts.each do |post| %>
            <%= link_to post_path(post), class: "text-decoration-none text-dark" do %>
              <div class="card mb-3 border-0 shadow-sm post-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between">
                    <div class="flex-grow-1">
                      <span class="badge category-badge mb-2">
                        <%= post.category&.name || "未分類" %>
                      </span>
                      <p class="fw-semibold mb-1"><%= post.title %></p>
                      <% if post.memo.present? %>
                        <p class="text-muted small mb-1 text-truncate"><%= post.memo %></p>
                      <% end %>
                      <small class="text-muted"><%= number_to_currency(post.amount, unit: "¥") %></small>
                    </div>
                    <div class="text-end small text-muted ms-3">
                      <div>by <%= post.user.name %></div>
                      <div><%= l post.created_at, format: :short %></div>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <p class="text-muted">投稿が見つかりませんでした</p>
        <% end %>
      </section>

    <% end %>
  </div>
</div>
<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">ユーザー管理</h2>
    <span class="text-muted small"><%= User.count %>名登録中</span>
  </div>

  <%= form_with url: admin_users_path, method: :get, local: true, class: "mb-4" do |f| %>
    <div class="input-group" style="max-width: 400px;">
      <%= f.text_field :q,
            value: params[:q],
            placeholder: "名前・メールで検索",
            class: "form-control rounded-pill rounded-end" %>
      <%= f.submit "検索", class: "btn btn-outline-secondary ms-2 rounded-pill" %>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>名前</th>
            <th>メール</th>
            <th>投稿数</th>
            <th>登録日</th>
            <th>admin</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td>
                <%= link_to user.name, admin_user_path(user), class: "fw-semibold text-decoration-none" %>
                <% if user == current_user %>
                  <span class="badge bg-success ms-1">あなた</span>
                <% end %>
              </td>
              <td class="text-muted small"><%= user.email %></td>
              <td><%= user.posts.count %></td>
              <td class="text-muted small"><%= l user.created_at, format: :short %></td>
              <td>
                <% if user.admin? %>
                  <span class="badge bg-danger">admin</span>
                <% else %>
                  <span class="badge bg-secondary">一般</span>
                <% end %>
              </td>
              <td class="text-end">
                <% unless user == current_user %>
                  <%= link_to user.admin? ? "admin剥奪" : "admin付与",
                        toggle_admin_admin_user_path(user),
                        method: :patch,
                        class: "btn btn-sm btn-outline-warning me-1" %>
                  <%= link_to "削除",
                        admin_user_path(user),
                        method: :delete,
                        data: { confirm: "#{user.name} を削除しますか？この操作は取り消せません。" },
                        class: "btn btn-sm btn-outline-danger" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
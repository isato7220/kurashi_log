<div class="container py-5">
  <div class="mb-3">
    <%= link_to "← ユーザー一覧に戻る", admin_users_path, class: "text-decoration-none small text-muted" %>
  </div>

  <div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-body d-flex align-items-center gap-4">
      <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold"
           style="width:56px; height:56px; font-size:1.4rem; flex-shrink:0;">
        <%= @user.name[0] %>
      </div>
      <div>
        <h3 class="fw-bold mb-1">
          <%= @user.name %>
          <% if @user.admin? %>
            <span class="badge bg-danger fs-6 ms-1">admin</span>
          <% end %>
        </h3>
        <p class="text-muted mb-0"><%= @user.email %></p>
        <small class="text-muted">登録日: <%= l @user.created_at, format: :short %></small>
      </div>
    </div>
  </div>

  <h5 class="fw-bold mb-3">投稿一覧（<%= @posts.size %>件）</h5>

  <% if @posts.any? %>
    <% @posts.each do |post| %>
      <%= link_to post_path(post), class: "text-decoration-none text-dark" do %>
        <div class="card mb-3 border-0 shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between">
              <div>
                <span class="badge bg-success-subtle text-success mb-1">
                  <%= post.category&.name || "未分類" %>
                </span>
                <p class="fw-semibold mb-1"><%= post.title %></p>
                <% if post.memo.present? %>
                  <p class="text-muted small mb-0"><%= post.memo %></p>
                <% end %>
              </div>
              <div class="text-end small text-muted">
                <div><%= number_to_currency(post.amount, unit: "¥") %></div>
                <div><%= l post.created_at, format: :short %></div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <p class="text-muted">まだ投稿がありません</p>
  <% end %>
</div>
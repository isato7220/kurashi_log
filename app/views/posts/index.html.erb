<div class="container py-5">
  <div class="mx-auto">

    <div class="mb-3">
      <%= link_to "← ホームへ戻る", root_path,
            class: "text-decoration-none small text-muted" %>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="fw-bold mb-1">みんなの暮らし</h2>
        <p class="text-muted small mb-0">
          日々の生活記録を振り返ってみましょう 🌿
        </p>
      </div>

      <%= link_to "＋ 新規投稿",
            new_post_path,
            class: "btn btn-success rounded-3 px-4" %>
    </div>

    <% @posts.each do |post| %>
      <%= link_to post_path(post), class: "text-decoration-none text-dark" do %>
        <div class="card mb-3 border-0 shadow-sm post-card">
          <div class="card-body">
            <div class="d-flex justify-content-between">

              <div class="flex-grow-1">
                <span class="badge category-badge mb-2">
                  <%= post.category&.name || "未分類" %>
                </span>
                <p class="fw-semibold mb-1"><%= post.title %></p>
                <% if post.memo.present? %>
                  <p class="text-muted small mb-1 text-truncate"><%= post.memo %></p>
                <% end %>
                <small class="text-muted">
                  <%= number_to_currency(post.amount, unit: "¥") %>
                </small>
              </div>

              <div class="text-end small text-muted ms-3">
                <div>by <%= post.user.name %></div>
                <div><%= l post.created_at, format: :short %></div>
              </div>

            </div>
          </div>
        </div>
      <% end %>
    <% end %>

  </div>
</div>